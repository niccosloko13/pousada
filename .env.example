# Neon (recommended for this project)
# Example: postgresql://USER:PASSWORD@ep-xxxx-xxxx-xxxx.region.aws.neon.tech/neondb?sslmode=verify-full&channel_binding=require
DATABASE_URL=""

# Mercado Pago (sandbox)
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
MERCADOPAGO_WEBHOOK_SECRET=""
# Optional: if you need the public key in client components
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=""

# App URLs (used in Mercado Pago back_urls / webhooks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# WhatsApp oficial da pousada (E.164)
NEXT_PUBLIC_WHATSAPP_E164="+5513996589014"

# Segurança do admin (obrigatório em produção, mínimo 32 caracteres)
ADMIN_SESSION_SECRET="troque-por-um-segredo-longo-e-aleatorio"
ADMIN_CONFIG_SECRET="troque-por-um-segredo-longo-e-aleatorio"

# Admin bootstrap (seed)
ADMIN_EMAIL="admin@pousada.local"
ADMIN_PASSWORD="admin123"

# Optional: protect admin mutation APIs
ADMIN_API_SECRET="change-me"
